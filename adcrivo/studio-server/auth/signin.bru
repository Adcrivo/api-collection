meta {
  name: signin
  type: http
  seq: 1
}

post {
  url: {{studio-backend-uri}}api/auth/signin
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@adcrivo.com",
    "password": "password"
  }
}

script:post-response {
  if (res.status === 200 && res.body.accessToken) {
    bru.setVar("studio-token", res.body.accessToken);
    console.log("Token updated successfully!");
  } else {
    console.log("Failed to update token. Status:", res.status, "Body:", res.body);
  }
}
